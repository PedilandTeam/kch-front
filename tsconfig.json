{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@app/*": [
        "./app/*"
      ],
      "@client-packages/*": [
        "./app/client-packages/*"
      ],
      "@text/*": [
        "./app/text/*"
      ],
      "@daisyComponents/*": [
        "./components/daisy/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/header.tsx",
    "app/header.tsx",
    "components/elements/badgenew.jsx",
    "components/elements/badgenew.jsx",
    ".next/types/**/*.ts"
, "app/layout/backtotop.jsx", "app/jobs/text.tsx", "app/jobs/page.tsx"  ],
  "exclude": [
    "node_modules"
  ]
}
